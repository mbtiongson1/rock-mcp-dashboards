{
  "name": "rock-mcp",
  "version": "1.0.1",
  "description": "Rock RMS MCP Server and MCP Apps for Favor Church Manila",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:stdio": "tsx src/server.ts --stdio",
    "build": "npm run build:apps && next build --webpack",
    "build:apps": "tsx scripts/build-report-viewer.ts",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "next start",
    "start:stdio": "node dist/server.js --stdio",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.0.1",
    "@upstash/redis": "^1.31.0",
    "jose": "^6.2.3",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "tsx": "^4.10.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^1.6.0"
  }
}
